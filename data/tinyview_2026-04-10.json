        "url": "https://cdn.tinyview.com/nick-anderson/2026/04/08/the-man-who-cried-apocalypse/040926.TACO_Scarface_Iran-copy.jpg",
        "alt": "https://cdn.tinyview.com/nick-anderson/2026/04/08/the-man-who-cried-apocalypse/040926.TACO_Scarface_Iran-copy.jpg",
